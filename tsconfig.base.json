{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false,
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@pervaxis/canvas-platform-http": ["./libs/platform/http/src/index.ts"],
      "@pervaxis/canvas-mfe-contracts": ["./libs/mfe/contracts/src/index.ts"],
      "@pervaxis/canvas-platform-auth": ["./libs/platform/auth/src/index.ts"],
      "@pervaxis/canvas-platform-state": ["./libs/platform/state/src/index.ts"],
      "@pervaxis/canvas-platform-error": ["./libs/platform/error/src/index.ts"],
      "@pervaxis/canvas-platform-i18n": ["./libs/platform/i18n/src/index.ts"],
      "@pervaxis/canvas-shell-core": ["./libs/shell/core/src/index.ts"],
      "@pervaxis/canvas-shell-routing": ["./libs/shell/routing/src/index.ts"],
      "@pervaxis/canvas-shell-auth": ["./libs/shell/auth/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
