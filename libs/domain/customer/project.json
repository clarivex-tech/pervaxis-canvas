{
  "name": "canvas-domain-customer",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/customer/src",
  "prefix": "customer",
  "projectType": "library",
  "tags": ["scope:domain", "type:sample"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/domain/customer/ng-package.json",
        "tsConfig": "libs/domain/customer/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/domain/customer/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
